.card {
  background: rgba(255,255,255,0.96);
  border-radius: 56rpx; box-shadow: 0 25rpx 45rpx rgba(0,0,0,0.25);
  padding: 28rpx 24rpx 36rpx;
}
.title-section { text-align: center; margin-bottom: 28rpx; }
.title-text { font-size: 36rpx; font-weight: 700; margin: 10rpx 0; color: #1f3b4c; }
.sub {
  font-size: 24rpx; color: #4a6272; background: #eef2f5;
  padding: 6rpx 16rpx; border-radius: 40rpx; display: inline-block; font-weight: 500;
  margin: 4rpx 0;
}
.sub-line { display: block; }
.back-btn {
  display: inline-block; margin-bottom: 16rpx; padding: 8rpx 20rpx;
  background: #eef3f7; border-radius: 40rpx; font-size: 26rpx; color: #1e6f8c; font-weight: 500;
}
.scroll-wrap { max-height: 60vh; }
.building-group {
  margin-bottom: 20rpx; background: #f8fafc; border-radius: 40rpx;
  padding: 16rpx 24rpx; border: 2rpx solid #e2edf2;
}
.building-title { font-weight: 600; color: #1e2f3a; font-size: 28rpx; margin-bottom: 10rpx; }
.level-inputs { display: flex; align-items: center; justify-content: space-between; }
.input-label-sm {
  font-weight: 500; color: #4a6272; font-size: 24rpx;
  background: #e9f0f3; padding: 6rpx 14rpx; border-radius: 40rpx;
}
.picker-text { font-size: 26rpx; font-weight: 600; color: #0b2b38; text-align: center; padding: 6rpx; }
.btn-container { display: flex; gap: 16rpx; margin: 24rpx 0; }
.calc-btn {
  background: linear-gradient(105deg, #1e6f8c, #0e4b62) !important;
  flex: 1; border: none; padding: 22rpx 0 !important; border-radius: 60rpx;
  color: white !important; font-size: 30rpx !important; font-weight: 700;
  box-shadow: 0 8rpx 0 #0a3140; line-height: 1.5 !important;
}
.calc-btn::after { border: none; }
.reset-btn {
  background: linear-gradient(105deg, #8c4a1e, #62310a) !important;
  flex: 1; border: none; padding: 22rpx 0 !important; border-radius: 60rpx;
  color: white !important; font-size: 30rpx !important; font-weight: 700;
  box-shadow: 0 8rpx 0 #40210a; line-height: 1.5 !important;
}
.reset-btn::after { border: none; }
.result-area {
  background: #0f212e; border-radius: 44rpx; padding: 28rpx 24rpx;
  margin-top: 24rpx; color: #f2e8cf;
}
.result-label {
  font-size: 24rpx; color: #9bbecf; text-align: center; margin-bottom: 16rpx; letter-spacing: 2rpx;
}
.single-result {
  display: flex; justify-content: space-between; padding: 10rpx 0;
  font-size: 28rpx; font-weight: bold;
  border-bottom: 2rpx solid rgba(155,190,207,0.1);
}
.total-result {
  display: flex; justify-content: space-between; padding: 16rpx 0;
  font-size: 34rpx; font-weight: bold; margin-top: 14rpx; color: #ffd700;
}
.err { color: #e53935; text-align: center; margin: 14rpx 0; font-size: 26rpx; }
.footer-sponsor-container { display: flex; justify-content: center; margin-top: 30rpx; }
.sponsor-footer {
  font-size: 24rpx; font-weight: 600; background: rgba(30,55,70,0.1);
  padding: 10rpx 20rpx; border-radius: 60rpx; color: #2c6f8c;
}
