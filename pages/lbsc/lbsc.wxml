<view class="card">
  <view class="title-section">
    <navigator url="/pages/index/index" class="back-btn">← 返回主页</navigator>
    <view class="title-text">⚔️ 开始练兵时间 · 精密计算</view>
    <!-- <view class="sub">单次练兵时长 × 3 + 爆兵日日期 → 开始时间</view> -->
  </view>

  <view class="input-group date-group">
    <text class="input-label">📅 爆兵日日期</text>
    <picker mode="date" value="{{targetDate}}" bindchange="onDateChange">
      <view class="date-picker-val">{{targetDate || '请选择日期'}}</view>
    </picker>
  </view>

  <view class="input-group">
    <text class="input-label">⏱️ 单兵营练兵时长</text>
    <view class="time-inputs">
      <input type="number" class="time-input" value="{{hours}}" bindinput="onHoursInput" />
      <text class="colon">:</text>
      <input type="digit" maxlength="2" class="time-input" value="{{minutesDisplay}}" bindinput="onMinutesInput" bindblur="onMinutesBlur" />
    </view>
  </view>
  <view class="hint">✨ 小时范围 0~23 | 分钟 0~59</view>

  <view class="quick-row">
    <button class="quick-btn" bindtap="onQuick" data-hours="6" data-mins="0">📌 6:00</button>
    <button class="quick-btn" bindtap="onQuick" data-hours="8" data-mins="20">📌 8:20</button>
    <button class="quick-btn" bindtap="onQuick" data-hours="10" data-mins="45">📌 10:45</button>
    <button class="quick-btn" bindtap="onQuick" data-hours="12" data-mins="35">📌 12:35</button>
  </view>

  <button class="calc-btn" bindtap="onCalc">⚡ 计算开始练兵时间 ⚡</button>

  <view class="result-area" wx:if="{{resultDisplay}}">
    <view class="result-label">📊开始练兵时间</view>
    <view class="result-value">{{resultDisplay}}</view>
    <view class="result-sub">总练兵时长 {{totalDurationText}}</view>
  </view>

  <view class="footer-sponsor-container">
    <view class="sponsor-footer">🎖️ 113AKA 友情赞助 · 招移民落地送八级矿 🎖️</view>
  </view>
</view>
