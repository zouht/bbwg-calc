.card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 56rpx;
  box-shadow: 0 25rpx 45rpx rgba(0, 0, 0, 0.25);
  padding: 40rpx 24rpx 50rpx;
  text-align: center;
}

.title-section {
  margin-bottom: 50rpx;
}

.title-text {
  font-size: 36rpx;
  font-weight: 700;
  margin: 20rpx 0 10rpx;
  color: #1f3b4c;
}

.main-btn {
  background: linear-gradient(105deg, #1e6f8c, #0e4b62);
  width: 100%;
  padding: 28rpx 0;
  border-radius: 60rpx;
  color: white;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  margin: 10rpx 0 30rpx;
  box-shadow: 0 8rpx 0 #0a3140;
  text-align: center;
}

.main-btn:active {
  transform: translateY(4rpx);
  box-shadow: 0 4rpx 0 #0a3140;
}

.footer-sponsor-container {
  display: flex;
  justify-content: center;
  margin-top: 40rpx;
}

.sponsor-footer {
  font-size: 24rpx;
  font-weight: 600;
  background: rgba(30, 55, 70, 0.1);
  padding: 12rpx 24rpx;
  border-radius: 60rpx;
  color: #2c6f8c;
}
